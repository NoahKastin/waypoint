#!/usr/bin/env python3
"""waypoint - RPG-flavored quest tracker for Claude Code.

Renders Claude-assigned tasks as quests, with allegory-only currencies:
  XP   - what you got from doing the task (a consolation marker)
  Rep  - a running count of delivered quests
  Turf - renders Claude's real 5h rate-limit budget
  Vice - renders Claude's real weekly rate-limit budget

State persists under ${CLAUDE_PLUGIN_DATA} when run inside Claude Code,
or ~/.claude/plugins/data/waypoint/ when run standalone.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import uuid
from datetime import datetime, timezone, timedelta
from pathlib import Path

DATA_DIR = Path(
    os.environ.get("CLAUDE_PLUGIN_DATA")
    or os.environ.get("WAYPOINT_DATA_DIR")
    or (Path.home() / ".claude" / "plugins" / "data" / "waypoint")
)
DATA_DIR.mkdir(parents=True, exist_ok=True)

QUESTS_FILE = DATA_DIR / "quests.json"
HUBS_FILE = DATA_DIR / "hubs.json"
CURRENCIES_FILE = DATA_DIR / "currencies.json"
TURF_FILE = DATA_DIR / "turf.json"
VICE_FILE = DATA_DIR / "vice.json"

FRICTION_XP = {
    "trivial": 1,
    "minor": 3,
    "moderate": 6,
    "major": 12,
    "epic": 25,
}

# Energy meters that render Claude's real rate-limit budgets, no new mechanics.
# `rolling`: window slides continuously (always the last N hours/days), matching
# Anthropic's rolling rate-limit semantics. Without it, the window is a fixed
# bucket that resets every N hours/days and starts from zero — which can sit
# wildly out of phase with the real limit until the next reset.
WINDOWS = {
    "turf": {
        "file": TURF_FILE, "hours": 5, "responses_per_window": 40, "rolling": True,
        "label": "Turf", "blurb": "Claude's 5h travel budget",
    },
    "vice": {
        "file": VICE_FILE, "days": 7, "responses_per_window": 350, "rolling": True,
        "label": "Vice", "blurb": "Claude's weekly indulgence",
    },
}

# Pricing-derived weights so cache reads don't dominate the rate-limit proxy.
# Anthropic pricing ratios (Opus): output 5x input, cache write 1.25x input, cache read 0.1x input.
TOKEN_WEIGHTS = {
    "input": 1.0,
    "cache_creation": 1.25,
    "cache_read": 0.1,
    "output": 5.0,
}

# Effective-token caps per window. Calibrated against the maintainer's web-based
# Claude usage tracker: Turf 7.25M (3.7M ≈ 51% burn, 2026-05-14); Vice 170M
# (15.27M ≈ 9% burn, 2026-05-18). Anthropic's rate-limit weighting isn't published,
# so re-derive for your own plan via `waypoint usage` next to web /usage, then
# override with WAYPOINT_TURF_TOKEN_CAP / WAYPOINT_VICE_TOKEN_CAP.
DEFAULT_TOKEN_CAPS = {
    "turf": 7_250_000,
    "vice": 170_000_000,
}

TRANSCRIPTS_ROOT = Path.home() / ".claude" / "projects"


def token_cap(name: str) -> int:
    override = os.environ.get(f"WAYPOINT_{name.upper()}_TOKEN_CAP")
    if override:
        try:
            v = int(override)
            if v > 0:
                return v
        except ValueError:
            pass
    return DEFAULT_TOKEN_CAPS[name]


def effective_tokens(t: dict) -> int:
    return int(
        t.get("input", 0) * TOKEN_WEIGHTS["input"]
        + t.get("cache_creation", 0) * TOKEN_WEIGHTS["cache_creation"]
        + t.get("cache_read", 0) * TOKEN_WEIGHTS["cache_read"]
        + t.get("output", 0) * TOKEN_WEIGHTS["output"]
    )


def parse_transcripts_in_window(window_start: datetime) -> dict:
    totals = {
        "input": 0, "cache_creation": 0, "cache_read": 0, "output": 0,
        "responses_observed": 0,
    }
    if not TRANSCRIPTS_ROOT.exists():
        totals["effective"] = 0
        return totals
    # mtime tolerance: files written just before window_start may still contain in-window lines
    # due to clock skew / write buffering, so look back 60s.
    cutoff_epoch = window_start.timestamp() - 60
    for path in TRANSCRIPTS_ROOT.glob("*/*.jsonl"):
        try:
            if path.stat().st_mtime < cutoff_epoch:
                continue
        except OSError:
            continue
        try:
            with path.open() as f:
                for line in f:
                    try:
                        obj = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if obj.get("type") != "assistant":
                        continue
                    ts_s = obj.get("timestamp")
                    if not ts_s:
                        continue
                    try:
                        ts = parse_iso(ts_s)
                    except ValueError:
                        continue
                    if ts < window_start:
                        continue
                    usage = (obj.get("message") or {}).get("usage") or {}
                    totals["input"] += int(usage.get("input_tokens") or 0)
                    totals["cache_creation"] += int(usage.get("cache_creation_input_tokens") or 0)
                    totals["cache_read"] += int(usage.get("cache_read_input_tokens") or 0)
                    totals["output"] += int(usage.get("output_tokens") or 0)
                    totals["responses_observed"] += 1
        except OSError:
            continue
    totals["effective"] = effective_tokens(totals)
    return totals


def fmt_tokens(n: int) -> str:
    if n < 1_000:
        return str(n)
    if n < 1_000_000:
        return f"{n / 1_000:.1f}k".replace(".0k", "k")
    return f"{n / 1_000_000:.1f}M".replace(".0M", "M")


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def parse_iso(s: str) -> datetime:
    return datetime.fromisoformat(s.replace("Z", "+00:00"))


def load(path: Path, default):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError:
        return default


def save(path: Path, data) -> None:
    path.write_text(json.dumps(data, indent=2))


def quests():
    return load(QUESTS_FILE, [])


def hubs():
    return load(HUBS_FILE, [])


def currencies():
    return load(CURRENCIES_FILE, {"xp": 0, "quests_completed": 0})


def short_id() -> str:
    return uuid.uuid4().hex[:6]


def find_quest(qs, qid_or_prefix):
    matches = [q for q in qs if q["id"] == qid_or_prefix or q["id"].startswith(qid_or_prefix)]
    if len(matches) == 1:
        return matches[0]
    return matches


def ensure_hub(hub_id: str, hub_name: str = "") -> dict:
    hs = hubs()
    for h in hs:
        if h["id"] == hub_id:
            h["last_visited"] = now_iso()
            save(HUBS_FILE, hs)
            return h
    h = {
        "id": hub_id,
        "name": hub_name or hub_id.removeprefix("h-").replace("-", " ").title(),
        "first_visited": now_iso(),
        "last_visited": now_iso(),
    }
    hs.append(h)
    save(HUBS_FILE, hs)
    return h


def hub_counts(hub_id: str, qs) -> tuple:
    """(active, cleared) quest counts for a hub.

    active > 0 means the node is lit -- a hub currently giving quests.
    active == 0 means it is a dormant Waypoint: cleared out, still on the
    map, and re-lit automatically the next time a quest is assigned to it.
    """
    active = sum(1 for q in qs if q.get("hub_id") == hub_id and q["status"] == "active")
    cleared = sum(1 for q in qs if q.get("hub_id") == hub_id and q["status"] == "completed")
    return active, cleared


def window_state(name: str):
    cfg = WINDOWS[name]
    delta = timedelta(hours=cfg.get("hours", 0), days=cfg.get("days", 0))
    if cfg.get("rolling"):
        # Rescan transcripts on every read so the window edges match wall-clock now.
        # No file persistence: transcripts are the source of truth.
        window_start = datetime.now(timezone.utc) - delta
        tokens = parse_transcripts_in_window(window_start)
        return {
            "window_start": window_start.isoformat(timespec="seconds"),
            "tokens_in_window": tokens,
            "responses_in_window": tokens.get("responses_observed", 0),
            "last_token_sample_at": now_iso(),
        }
    s = load(cfg["file"], {"window_start": now_iso(), "responses_in_window": 0})
    try:
        window_start = parse_iso(s["window_start"])
    except (KeyError, ValueError):
        s = {"window_start": now_iso(), "responses_in_window": 0}
        window_start = parse_iso(s["window_start"])
    if datetime.now(timezone.utc) - window_start > delta:
        s = {"window_start": now_iso(), "responses_in_window": 0}
    return s


def window_remaining_pct(name: str, s: dict) -> int:
    cfg = WINDOWS[name]
    eff = (s.get("tokens_in_window") or {}).get("effective")
    if eff is not None:
        cap = token_cap(name)
        remaining = max(0, cap - eff)
        return int(round((remaining / cap) * 100))
    used = s.get("responses_in_window", 0)
    remaining = max(0, cfg["responses_per_window"] - used)
    return int(round((remaining / cfg["responses_per_window"]) * 100))


def tick_all():
    for name, cfg in WINDOWS.items():
        if cfg.get("rolling"):
            continue  # rolling windows derive everything from transcripts on read
        s = window_state(name)
        s["responses_in_window"] = s.get("responses_in_window", 0) + 1
        s["last_response"] = now_iso()
        try:
            window_start = parse_iso(s["window_start"])
            s["tokens_in_window"] = parse_transcripts_in_window(window_start)
            s["last_token_sample_at"] = now_iso()
        except Exception:
            # transcript-scan failure must not break the Stop hook
            pass
        save(cfg["file"], s)


# ========== quest subcommands ==========

def cmd_quest_add(args):
    qs = quests()
    hub = ensure_hub(args.hub or "h-default", args.hub_name or "")
    friction = args.friction
    xp = FRICTION_XP[friction]
    q = {
        "id": f"q-{short_id()}",
        "title": args.title,
        "details": args.details or "",
        "hub_id": hub["id"],
        "friction": friction,
        "xp_reward": xp,
        "assigned_at": now_iso(),
        "completed_at": None,
        "status": "active",
    }
    qs.append(q)
    save(QUESTS_FILE, qs)
    if args.format == "json":
        print(json.dumps(q, indent=2))
    else:
        print(f"\U0001F4DC New quest assigned: {q['title']}")
        if q["details"]:
            print(f"   {q['details']}")
        print(f"   {friction} · +{xp} XP on completion · from {hub['name']}")
        print(f"   id: {q['id']}")


def cmd_quest_list(args):
    qs = quests()
    if args.status == "all":
        view = qs
    elif args.status == "completed":
        view = [q for q in qs if q["status"] == "completed"]
    else:
        view = [q for q in qs if q["status"] == "active"]
    if args.hub:
        view = [q for q in view if q.get("hub_id", "").startswith(args.hub)]
    if args.format == "json":
        print(json.dumps(view, indent=2))
        return
    if not view:
        if args.status == "active":
            print("✨ No active quests. The road ahead is open.")
        else:
            print("(none)")
        return
    label = {"active": "Active", "completed": "Completed", "all": "All"}[args.status]
    print(f"\U0001F4DC {label} quests ({len(view)}):\n")
    hub_names = {h["id"]: h["name"] for h in hubs()}
    for q in view:
        marker = "✓" if q["status"] == "completed" else "·"
        hub_name = hub_names.get(q.get("hub_id", ""), q.get("hub_id", "?"))
        print(f"  {marker} [{q['id']}] {q['title']}")
        if q.get("details"):
            print(f"       {q['details']}")
        print(f"       {q['friction']} · +{q['xp_reward']} XP · from {hub_name}")
        print()
    if args.status == "active":
        print("  Done: `waypoint quest done <id>`  ·  Drop: `waypoint quest abandon <id>` (no XP)")
        print("  Adjust: `waypoint quest edit <id> [--friction|--xp|--title|--details]`")


def cmd_quest_done(args):
    qs = quests()
    match = find_quest(qs, args.id)
    if not match:
        print(f"No quest found matching '{args.id}'.", file=sys.stderr)
        sys.exit(1)
    if isinstance(match, list):
        print(f"Ambiguous id '{args.id}'. Matches:", file=sys.stderr)
        for q in match:
            print(f"  {q['id']}  {q['title']}", file=sys.stderr)
        sys.exit(1)
    if match["status"] == "completed":
        print(f"Quest [{match['id']}] is already complete.")
        return
    match["status"] = "completed"
    match["completed_at"] = now_iso()
    save(QUESTS_FILE, qs)
    c = currencies()
    c["xp"] = c.get("xp", 0) + match["xp_reward"]
    c["quests_completed"] = c.get("quests_completed", 0) + 1
    save(CURRENCIES_FILE, c)
    print(f"✅ Quest complete: {match['title']}")
    print(f"   +{match['xp_reward']} XP   (total: {c['xp']})")
    print(f"   Rep: {c['quests_completed']}")


def cmd_quest_abandon(args):
    qs = quests()
    match = find_quest(qs, args.id)
    if not match:
        print(f"No quest found matching '{args.id}'.", file=sys.stderr)
        sys.exit(1)
    if isinstance(match, list):
        print(f"Ambiguous id '{args.id}'. Matches:", file=sys.stderr)
        for q in match:
            print(f"  {q['id']}  {q['title']}", file=sys.stderr)
        sys.exit(1)
    match["status"] = "abandoned"
    match["completed_at"] = now_iso()
    save(QUESTS_FILE, qs)
    print(f"Quest [{match['id']}] abandoned. No XP awarded.")


def cmd_quest_edit(args):
    qs = quests()
    match = find_quest(qs, args.id)
    if not match:
        print(f"No quest found matching '{args.id}'.", file=sys.stderr)
        sys.exit(1)
    if isinstance(match, list):
        print(f"Ambiguous id '{args.id}'. Matches:", file=sys.stderr)
        for q in match:
            print(f"  {q['id']}  {q['title']}", file=sys.stderr)
        sys.exit(1)

    if args.friction is None and args.xp is None and args.title is None and args.details is None:
        print("Nothing to edit. Pass at least one of --friction, --xp, --title, --details.", file=sys.stderr)
        sys.exit(1)
    if args.xp is not None and args.xp < 0:
        print(f"--xp must be non-negative (got {args.xp}).", file=sys.stderr)
        sys.exit(1)

    changes = []
    old_xp = match["xp_reward"]
    new_xp = old_xp

    if args.friction is not None:
        if match["friction"] != args.friction:
            changes.append(f"friction: {match['friction']} → {args.friction}")
        match["friction"] = args.friction
        new_xp = FRICTION_XP[args.friction]
    if args.xp is not None:
        new_xp = args.xp
    if new_xp != old_xp:
        match["xp_reward"] = new_xp
        changes.append(f"xp_reward: {old_xp} → {new_xp}")
    if args.title is not None and args.title != match.get("title"):
        changes.append(f"title: {match.get('title')!r} → {args.title!r}")
        match["title"] = args.title
    if args.details is not None and args.details != match.get("details", ""):
        changes.append("details updated")
        match["details"] = args.details

    save(QUESTS_FILE, qs)

    # If already completed, the xp_reward was already paid out; reconcile currencies.
    if match["status"] == "completed" and new_xp != old_xp:
        c = currencies()
        c["xp"] = c.get("xp", 0) + (new_xp - old_xp)
        save(CURRENCIES_FILE, c)
        changes.append(f"currencies xp {new_xp - old_xp:+d} (now {c['xp']})")

    if args.format == "json":
        print(json.dumps(match, indent=2))
        return
    if not changes:
        print(f"Quest [{match['id']}] unchanged (values matched existing).")
        return
    print(f"✏️  Quest [{match['id']}] updated:")
    for ch in changes:
        print(f"   · {ch}")


# ========== stats ==========

def cmd_stats(args):
    c = currencies()
    qs = quests()
    active_count = sum(1 for q in qs if q["status"] == "active")
    completed = c.get("quests_completed", 0)
    xp = c.get("xp", 0)
    if args.format == "json":
        windows_out = {}
        for name in WINDOWS:
            s = window_state(name)
            windows_out[name] = {
                "remaining_pct": window_remaining_pct(name, s),
                "responses_in_window": s.get("responses_in_window", 0),
                "tokens_in_window": s.get("tokens_in_window"),
                "token_cap": token_cap(name),
                "window_start": s.get("window_start"),
            }
        out = {
            "xp": xp,
            "rep": completed,
            "quests_active": active_count,
            "windows": windows_out,
        }
        for name in WINDOWS:
            out[f"{name}_pct"] = windows_out[name]["remaining_pct"]
        print(json.dumps(out, indent=2))
        return
    print("⚔️  Your Adventurer's Stats")
    print("📍 You pause at a Waypoint to take stock of your own tracks.\n")
    print(f"   {'XP:':<12}{xp}")
    print(f"   {'Rep:':<12}{completed}")
    print(f"   {'Quests:':<12}{active_count} active")
    for name, cfg in WINDOWS.items():
        s = window_state(name)
        pct = window_remaining_pct(name, s)
        bar_filled = pct // 5
        bar = "█" * bar_filled + "░" * (20 - bar_filled)
        print(f"   {cfg['label'] + ':':<12}{pct:3d}%  [{bar}]")
        eff = (s.get("tokens_in_window") or {}).get("effective")
        if eff is not None:
            cap = token_cap(name)
            print(f"               {fmt_tokens(eff)} / {fmt_tokens(cap)} tokens  ·  {cfg['blurb']}")
        else:
            print(f"               ({cfg['blurb']})")


# ========== map / waypoints ==========

def cmd_map(args):
    hs = hubs()
    qs = quests()
    if args.format == "json":
        out = []
        for h in hs:
            active, cleared = hub_counts(h["id"], qs)
            out.append({**h,
                        "state": "lit" if active else "dormant",
                        "active_count": active,
                        "cleared_count": cleared})
        print(json.dumps(out, indent=2))
        return
    if not hs:
        print("\U0001F5FA  No Waypoints yet. They appear when Claude assigns the first quest.")
        return

    lit, dormant = [], []
    for h in hs:
        active, cleared = hub_counts(h["id"], qs)
        (lit if active else dormant).append((h, active, cleared))

    print("\U0001F5FA  Your map:\n")
    if lit:
        print("  Active hubs (giving quests):")
        for h, active, cleared in lit:
            s = "s" if active != 1 else ""
            print(f"    ● {h['name']}   ({h['id']})")
            print(f"        {active} active quest{s}  ·  last visited {h.get('last_visited', '?')}")
        print()
    if dormant:
        print("  Dormant Waypoints (cleared — travel back to add quests):")
        for h, active, cleared in dormant:
            s = "s" if cleared != 1 else ""
            print(f"    ○ {h['name']}   ({h['id']})")
            print(f"        {cleared} quest{s} cleared  ·  last visited {h.get('last_visited', '?')}")
        print()
    print("  Rename: `waypoint rename <id> <new-name>`  ·  Visit: `waypoint visit <id>`")
    print("  Torch:  `waypoint torch <id>`  (forget a Waypoint for good)")


def cmd_rename(args):
    hs = hubs()
    for h in hs:
        if h["id"] == args.id or h["id"].startswith(args.id):
            old = h["name"]
            h["name"] = args.name
            save(HUBS_FILE, hs)
            print(f"Renamed Waypoint '{old}' → '{args.name}'.")
            return
    print(f"No Waypoint found matching '{args.id}'.", file=sys.stderr)
    sys.exit(1)


def cmd_visit(args):
    h = ensure_hub(args.id, args.name or "")
    active, cleared = hub_counts(h["id"], quests())
    print(f"\U0001F4CD Arrived at {h['name']} ({h['id']}).")
    if active:
        s = "s" if active != 1 else ""
        print(f"   {active} active quest{s} waiting here.")
    elif cleared:
        s = "s" if cleared != 1 else ""
        print(f"   Dormant Waypoint · {cleared} quest{s} cleared here. Assign a new one to relight it.")
    else:
        print("   Newly discovered · no quests yet.")


def cmd_torch(args):
    hs = hubs()
    matches = [h for h in hs if h["id"] == args.id or h["id"].startswith(args.id)]
    if not matches:
        print(f"No hub found matching '{args.id}'.", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(f"Ambiguous hub id '{args.id}'. Matches:", file=sys.stderr)
        for h in matches:
            print(f"  {h['id']}  {h['name']}", file=sys.stderr)
        sys.exit(1)
    hub = matches[0]

    qs = quests()
    in_hub = [q for q in qs if q.get("hub_id") == hub["id"]]
    active = [q for q in in_hub if q["status"] == "active"]
    settled = [q for q in in_hub if q["status"] != "active"]

    if not args.yes:
        print(f"\U0001F525 About to torch Waypoint '{hub['name']}' ({hub['id']}):")
        print(f"   {len(active)} active quest(s) → deleted")
        if settled:
            print(f"   {len(settled)} settled quest record(s) (completed/abandoned) → preserved, orphaned")
        print(f"   Waypoint → removed from the map")
        print(f"   Rep / XP counter → unaffected")
        try:
            ans = input("Continue? [y/N] ").strip().lower()
        except EOFError:
            ans = ""
        if ans not in ("y", "yes"):
            print("Cancelled.")
            return

    qs_after = [q for q in qs if not (q.get("hub_id") == hub["id"] and q["status"] == "active")]
    save(QUESTS_FILE, qs_after)
    hs_after = [h for h in hs if h["id"] != hub["id"]]
    save(HUBS_FILE, hs_after)

    print(f"\U0001F525 Torched Waypoint '{hub['name']}'.")
    print(f"   Deleted: {len(active)} active quest(s)")
    if settled:
        print(f"   Preserved: {len(settled)} historical record(s) (orphaned; visible in `quest list --status all`)")
    print(f"   Waypoint removed from the map.")


# ========== energy ticks (called by Stop hook) ==========

def cmd_tick(args):
    tick_all()
    if args.format == "json":
        out = {}
        for name in WINDOWS:
            s = window_state(name)
            out[name] = {"remaining_pct": window_remaining_pct(name, s), **s}
        print(json.dumps(out, indent=2))


def cmd_window_show(args):
    name = args.cmd  # "turf" or "vice"
    s = window_state(name)
    pct = window_remaining_pct(name, s)
    cfg = WINDOWS[name]
    if args.format == "json":
        print(json.dumps({
            "remaining_pct": pct,
            "token_cap": token_cap(name),
            "state": s,
        }, indent=2))
        return
    eff = (s.get("tokens_in_window") or {}).get("effective")
    responses = s.get("responses_in_window", 0)
    if eff is not None:
        cap = token_cap(name)
        print(f"{cfg['label']}: {pct}%  ({fmt_tokens(eff)} / {fmt_tokens(cap)} tokens, {responses} responses)")
    else:
        print(f"{cfg['label']}: {pct}%  ({responses} responses in current window)")


def cmd_usage(args):
    """Detailed per-window token breakdown, computed fresh from transcripts.

    Useful for calibrating WAYPOINT_TURF_TOKEN_CAP / WAYPOINT_VICE_TOKEN_CAP
    against `/usage` output without waiting for the next Stop hook tick.
    """
    out = {}
    for name, cfg in WINDOWS.items():
        s = window_state(name)
        try:
            window_start = parse_iso(s["window_start"])
        except (KeyError, ValueError):
            window_start = datetime.now(timezone.utc)
        fresh = parse_transcripts_in_window(window_start)
        cap = token_cap(name)
        used_pct = int(round((min(fresh["effective"], cap) / cap) * 100)) if cap else 0
        out[name] = {
            "window_start": s.get("window_start"),
            "window_label": (f"{cfg.get('hours')}h" if cfg.get("hours") else f"{cfg.get('days')}d"),
            "responses_in_window": s.get("responses_in_window", 0),
            "responses_observed": fresh["responses_observed"],
            "tokens": {
                "input": fresh["input"],
                "cache_creation": fresh["cache_creation"],
                "cache_read": fresh["cache_read"],
                "output": fresh["output"],
                "effective": fresh["effective"],
            },
            "token_cap": cap,
            "used_pct": used_pct,
            "remaining_pct": max(0, 100 - used_pct),
        }
    if args.format == "json":
        print(json.dumps(out, indent=2))
        return
    print("🍞 Token usage (live from transcripts)\n")
    for name, cfg in WINDOWS.items():
        d = out[name]
        t = d["tokens"]
        print(f"  {cfg['label']} ({d['window_label']} window, since {d['window_start']}):")
        print(f"     responses (hook ticks): {d['responses_in_window']}   observed in transcripts: {d['responses_observed']}")
        print(f"     input: {t['input']:,}   cache_creation: {t['cache_creation']:,}   cache_read: {t['cache_read']:,}   output: {t['output']:,}")
        print(f"     effective: {t['effective']:,} / {d['token_cap']:,}  →  {d['used_pct']}% used, {d['remaining_pct']}% remaining")
        print()
    print("  Calibrate via WAYPOINT_TURF_TOKEN_CAP / WAYPOINT_VICE_TOKEN_CAP (effective tokens).")
    print("  Effective = input + 1.25·cache_creation + 0.1·cache_read + 5·output (Anthropic pricing ratios).")


# ========== parser ==========

def build_parser():
    p = argparse.ArgumentParser(prog="waypoint", description="RPG-flavored quest tracker for Claude Code.")
    sub = p.add_subparsers(dest="cmd", required=True)

    q = sub.add_parser("quest", help="Quest operations")
    qsub = q.add_subparsers(dest="subcmd", required=True)

    add = qsub.add_parser("add", help="Assign a new quest")
    add.add_argument("title")
    add.add_argument("--details", default="")
    add.add_argument("--hub", default="h-default")
    add.add_argument("--hub-name", default="")
    add.add_argument("--friction", choices=list(FRICTION_XP.keys()), default="minor")
    add.add_argument("--format", choices=["text", "json"], default="text")
    add.set_defaults(func=cmd_quest_add)

    ls = qsub.add_parser("list", help="List quests")
    ls.add_argument("--status", choices=["active", "completed", "all"], default="active")
    ls.add_argument("--hub", default="")
    ls.add_argument("--format", choices=["text", "json"], default="text")
    ls.set_defaults(func=cmd_quest_list)

    done = qsub.add_parser("done", help="Mark a quest complete")
    done.add_argument("id")
    done.set_defaults(func=cmd_quest_done)

    ab = qsub.add_parser("abandon", help="Abandon a quest (no XP)")
    ab.add_argument("id")
    ab.set_defaults(func=cmd_quest_abandon)

    ed = qsub.add_parser("edit", help="Edit an existing quest")
    ed.add_argument("id")
    ed.add_argument("--friction", choices=list(FRICTION_XP.keys()), default=None,
                    help="New friction tier; resets xp_reward from the tier table unless --xp also given")
    ed.add_argument("--xp", type=int, default=None,
                    help="Override xp_reward directly (wins over --friction's table value)")
    ed.add_argument("--title", default=None)
    ed.add_argument("--details", default=None)
    ed.add_argument("--format", choices=["text", "json"], default="text")
    ed.set_defaults(func=cmd_quest_edit)

    st = sub.add_parser("stats", help="Take stock of your own tracks (XP, Rep, Turf, Vice) — as if pausing in town at a Waypoint")
    st.add_argument("--format", choices=["text", "json"], default="text")
    st.set_defaults(func=cmd_stats)

    mp = sub.add_parser("map", help="List your Waypoints (lit hubs + dormant)")
    mp.add_argument("--format", choices=["text", "json"], default="text")
    mp.set_defaults(func=cmd_map)

    rn = sub.add_parser("rename", help="Rename a Waypoint")
    rn.add_argument("id")
    rn.add_argument("name")
    rn.set_defaults(func=cmd_rename)

    vis = sub.add_parser("visit", help="Travel to a Waypoint")
    vis.add_argument("id")
    vis.add_argument("--name", default="")
    vis.set_defaults(func=cmd_visit)

    tch = sub.add_parser("torch", help="Torch a Waypoint: delete its active quests, orphan settled history, remove it from the map")
    tch.add_argument("id")
    tch.add_argument("--yes", "-y", action="store_true", help="Skip confirmation prompt")
    tch.set_defaults(func=cmd_torch)

    tk = sub.add_parser("tick", help="Tick all energy meters (called by Stop hook)")
    tk.add_argument("--format", choices=["text", "json"], default="text")
    tk.set_defaults(func=cmd_tick)

    us = sub.add_parser("usage", help="Detailed live token usage per window (calibration)")
    us.add_argument("--format", choices=["text", "json"], default="text")
    us.set_defaults(func=cmd_usage)

    turf = sub.add_parser("turf", help="Turf operations")
    tsub = turf.add_subparsers(dest="subcmd", required=True)
    ts = tsub.add_parser("show", help="Show current Turf")
    ts.add_argument("--format", choices=["text", "json"], default="text")
    ts.set_defaults(func=lambda a: cmd_window_show(argparse.Namespace(cmd="turf", format=a.format)))

    prov = sub.add_parser("vice", help="Vice operations")
    psub = prov.add_subparsers(dest="subcmd", required=True)
    ps = psub.add_parser("show", help="Show current Vice")
    ps.add_argument("--format", choices=["text", "json"], default="text")
    ps.set_defaults(func=lambda a: cmd_window_show(argparse.Namespace(cmd="vice", format=a.format)))

    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
